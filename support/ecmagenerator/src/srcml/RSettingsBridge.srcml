<class>class <macro><name>QCADCORE_EXPORT</name></macro> <name>RSettingsBridge</name> <super>: <specifier>public</specifier> <name>QObject</name></super> <block>{<private type="default">
    <macro><name>Q_OBJECT</name></macro>

</private><public>public:
    <function><type><name>static</name> <name>RSettingsBridge</name>*</type> <name>instance</name><parameter_list>()</parameter_list> <block>{
        <comment type="line">// If the instance doesn't exist yet, create it</comment>
        <if>if <condition>(<expr>!<name>m_instance</name></expr>)</condition><then> <block>{
            <expr_stmt><expr><name>m_instance</name> = new <call><name>RSettingsBridge</name><argument_list>()</argument_list></call></expr>;</expr_stmt>
            
            <comment type="line">// Optional: Ensure the instance is cleaned up when the app closes</comment>
            <comment type="line">// by setting the application object as the parent.</comment>
